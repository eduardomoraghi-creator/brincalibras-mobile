{
  "expo": {
    "name": "BrincaLibras",
    "slug": "brincalibras-sprint1",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "orientation": "portrait",
    "scheme": "brincalibras",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O app precisa acessar sua câmera para tirar uma foto de perfil.",
        "NSPhotoLibraryUsageDescription": "O app precisa acessar sua galeria para escolher uma foto de perfil."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brincalibras.app",
      "permissions": [
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./srcassets/images/adaptive-icon.png",
        "backgroundColor": "#2D9CDB"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar sua galeria para escolher uma foto de perfil.",
          "cameraPermission": "O app precisa acessar sua câmera para tirar uma foto de perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da4f67a7-0c5f-4b86-814a-5db7207ddaaa"
      }
    },
    "owner": "moraghi"
  }
}